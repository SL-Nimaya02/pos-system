# ─────────────────────────────────────────────────────────────────────────────
# POS System — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database Mode ────────────────────────────────────────────────────────────
# Controls which DB driver the app uses at runtime.
#   local        — mysql2 pool with individual vars below (default for dev)
#   cloud        — mysql2 pool with DATABASE_URL  (Railway, AWS RDS)
#   planetscale  — @planetscale/database HTTP driver (required for Vercel)
# If DB_MODE is unset: DATABASE_URL present → "cloud", otherwise → "local"
DB_MODE=local

# ─── Database — Local (DB_MODE=local) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_db

# ─── Database — Cloud (DB_MODE=cloud or DB_MODE=planetscale) ─────────────────
# PlanetScale:   mysql://user:pass@host/db?sslaccept=strict
# Railway MySQL: mysql://user:pass@host:port/db
# AWS RDS:       mysql://user:pass@host:3306/db
DATABASE_URL=

# ─── Authentication (NextAuth) ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full URL of the deployed app
NEXTAUTH_URL=http://localhost:3000

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Required only if using Stripe Terminal / card payments.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# For file/image storage and optional backup uploads.
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to browser
SUPABASE_SERVICE_KEY=

# ─── Backup (optional) ────────────────────────────────────────────────────────
# Supabase Storage bucket name. Leave blank for local-only backups (./backups/).
# Requires NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_KEY above.
BACKUP_BUCKET=

# ─── Clerk (legacy — not used, kept for reference) ───────────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
