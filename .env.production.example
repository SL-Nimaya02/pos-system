# ============================================================
#  PRODUCTION ENVIRONMENT — Copy these into Vercel
#  Settings → Environment Variables
# ============================================================

# --- Database (Railway MySQL) ---
DB_MODE=cloud
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# --- NextAuth ---
# IMPORTANT: Update NEXTAUTH_URL to your actual Vercel URL after first deploy
NEXTAUTH_SECRET=generate-a-long-random-secret
NEXTAUTH_URL=https://YOUR-PROJECT-NAME.vercel.app

# --- Stripe (leave as-is if not using real payments) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# --- Supabase (leave as-is if not using Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx
SUPABASE_BUCKET=product-images
